{
  "name": "@hootrix/openclaw-hootrix-trace",
  "version": "1.1.0",
  "license": "Apache-2.0",
  "description": "OpenClaw trace exporter — sends LLM traces to Hootrix",
  "repository": {
    "type": "git",
    "url": "https://github.com/hootrix-ai/openclaw-hootrix-trace"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run src/**/*.e2e.test.ts",
    "prepack": "npm run build",
    "smoke": "vitest run src/plugin.smoke.test.ts",
    "prebuild": "node scripts/ensure-hootrix.mjs",
    "postinstall": "node scripts/ensure-dist-shim.mjs",
    "dev:shim": "node scripts/ensure-dist-shim.mjs"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "hootrix": "^1.0.28"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.0"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "commander": "^14.0.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "@anthropic-ai/sdk": "^0.92.0",
    "uuid": "^14.0.0"
  },
  "files": [
    "dist/**",
    "index.ts",
    "src/cli.ts",
    "src/configure.ts",
    "src/device-auth.ts",
    "src/service.ts",
    "src/constants.ts",
    "src/plugin-instance-client.ts",
    "src/collector-url.ts",
    "src/collector-fetch.ts",
    "src/direct-collector-export.ts",
    "src/service/helpers.ts",
    "src/service/payload-sanitizer.ts",
    "src/service/media.ts",
    "src/service/trace-classification.ts",
    "src/service/attachment-uploader.ts",
    "src/service/hooks/gateway.ts",
    "src/service/hooks/llm.ts",
    "src/service/hooks/tool.ts",
    "src/service/hooks/subagent.ts",
    "src/trace-logger.ts",
    "src/types.ts",
    "openclaw.plugin.json",
    "public/logo.svg",
    "README.md",
    "LICENSE"
  ],
  "openclaw": {
    "extensions": ["./index.ts"],
    "runtimeExtensions": ["./dist/index.js"],
    "compat": {
      "pluginApi": ">=2026.3.2",
      "minGatewayVersion": "2026.3.2"
    },
    "build": {
      "openclawVersion": "2026.3.2",
      "pluginSdkVersion": "2026.3.2"
    }
  }
}
